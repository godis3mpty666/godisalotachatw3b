# Runtime data may contain OAuth tokens, passwords, cookies and personal data.
data/*
!data/.gitkeep
!data/__init__.py
!data/paths.py

# Local secrets and environment files
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
build/.signing-thumbprint
build/.version-before-build
build/contributor_passwords.txt
build/private/
shared/build_provenance.py
*credentials*.json
*oauth_cache*.json
*tokens*.json
*state*.json

# Browser profiles and session data
browser_profile*/
**/browser_profile*/
**/*_profile/
**/profile/

# Logs, databases and temporary runtime output
*.log
*.sqlite
*.sqlite3
*.db
*.tmp
*.bak
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage.xml
.coverage
htmlcov/

# Build and release artifacts
temp/
dist/
*.egg-info/

# Editors and operating systems
.idea/
.vscode/
.DS_Store
Thumbs.db
Desktop.ini
